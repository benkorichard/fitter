# Web -> API proxy target used by Vite dev server inside the web container.
# Examples:
# API_URL=http://api:8000
# API_URL=http://fitter-api:8000
API_URL=http://api:8000

# Comma-separated hostnames accepted by the Vite dev server.
# Examples:
# ALLOWED_HOSTS=localhost,127.0.0.1,fitter.benko.work
ALLOWED_HOSTS=localhost,127.0.0.1
